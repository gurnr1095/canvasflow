# Copy this file to .env and fill in real values. Do NOT commit your .env file.

# PostgreSQL connection string
DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/canvasflow

# Clerk — get from https://dashboard.clerk.com → your app → API Keys
CLERK_JWKS_URL=https://<your-clerk-domain>.clerk.accounts.dev/.well-known/jwks.json

# OpenRouter API key for AI generation
OPENROUTER_API_KEY=sk-or-v1-...

# Production frontend URL for CORS (leave empty for local dev)
FRONTEND_URL=
