# Copy this file to .env and fill in real values. Do NOT commit your .env file.

# Database URL example (Postgres)
# DATABASE_URL=postgresql://username:password@localhost:5432/dbname

# FastAPI/Secret key
SECRET_KEY=replace_with_a_secure_random_value

# Optional AI API key (if used)
# AI_API_KEY=replace_with_your_api_key

# Other environment variables used by the app
# EXAMPLE_VAR=value
